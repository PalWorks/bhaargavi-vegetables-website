# Google Apps Script Web App URL for order recording
# Deploy your Apps Script as a Web App (Execute as: Me, Who can access: Anyone)
# and paste the deployment URL here
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Featurable account ID for Google Reviews widget (get from featurable.com after free signup)
VITE_FEATURABLE_ID=

# Google Business Profile Place ID (for direct Google Review links)
VITE_GOOGLE_PLACE_ID=

# Bhaargavi Google Sheets ID (for fetch scripts)
BHAARGAVI_SHEETS_ID=1Ao_1pGEsPkCRgtOho02ZqaAUOsMUiuJiaTEsLbPHQW8

# Google Sheets API Key (for fetch scripts — same as TomeCafe secret)
SKUITEMMASTER_GOOGLE_SHEETS_API_KEY=

# Instagram Basic Display API token
INSTAGRAM_TOKEN=

# Cloudflare Pages deployment (set in GitHub Secrets)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
